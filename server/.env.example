# ==============================================================================
# BIDVAULT BACKEND ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# Copy this file to `.env` and fill in your keys
# ==============================================================================

PORT=5000
NODE_ENV=development
ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost

# 1. MONGODB DATABASE URL (Required)
# -> Local MongoDB: mongodb://localhost:27017/auction
# -> MongoDB Atlas (Cloud): mongodb+srv://<username>:<password>@cluster0.mongodb.net/auction
MONGO_URL=mongodb://localhost:27017/auction

# 2. JWT SECRET (Required for User Authentication & Cookies)
JWT_SECRET=your_super_secret_jwt_key_here_at_least_32_chars
JWT_EXPIRES_IN=7d

# 3. CLOUDINARY API KEYS (Required for item photo uploads)
# Get free keys at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 4. RESEND EMAIL API KEY (Optional - for welcome & password reset emails)
# Get free key at https://resend.com/
RESEND_API_KEY=re_your_resend_api_key
ADMIN_EMAIL=admin@yourdomain.com

# 5. IPINFO API KEY (Optional — for Login Geolocation history)
IPINFO_API_KEY=your_ipinfo_token
